{
  "info": {
    "name": "Simple LMS API",
    "description": "REST API for Simple Learning Management System dengan Django Ninja dan JWT Authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST /api/auth/register - Register new user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"instructor1\",\n  \"email\": \"instructor1@example.com\",\n  \"password\": \"password123\",\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Smith\",\n  \"role\": \"instructor\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "POST /api/auth/login - Login (return JWT tokens)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"instructor1\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "POST /api/auth/refresh - Refresh access token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            }
          }
        },
        {
          "name": "GET /api/auth/me - Get current user",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "PUT /api/auth/me - Update profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Updated\",\n  \"last_name\": \"Name\",\n  \"email\": \"updated@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Courses (Public)",
      "item": [
        {
          "name": "GET /api/courses/ - List courses (with pagination & filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/courses/?search=python&min_price=0&max_price=100000",
              "host": ["{{base_url}}"],
              "path": ["api", "courses"],
              "query": [
                {
                  "key": "search",
                  "value": "python"
                },
                {
                  "key": "min_price",
                  "value": "0"
                },
                {
                  "key": "max_price",
                  "value": "100000"
                }
              ]
            }
          }
        },
        {
          "name": "GET /api/courses/{id} - Course detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/courses/1",
              "host": ["{{base_url}}"],
              "path": ["api", "courses", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Courses (Protected)",
      "item": [
        {
          "name": "POST /api/courses/ - Create course (Instructor)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Python Programming\",\n  \"description\": \"Belajar Python dari dasar\",\n  \"price\": 150000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/courses/",
              "host": ["{{base_url}}"],
              "path": ["api", "courses"]
            }
          }
        },
        {
          "name": "PATCH /api/courses/{id} - Update course (Owner)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Python Programming - Updated\",\n  \"price\": 200000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/courses/1",
              "host": ["{{base_url}}"],
              "path": ["api", "courses", "1"]
            }
          }
        },
        {
          "name": "DELETE /api/courses/{id} - Delete course (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/courses/1",
              "host": ["{{base_url}}"],
              "path": ["api", "courses", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "POST /api/enrollments/ - Enroll to course (Student)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/enrollments/",
              "host": ["{{base_url}}"],
              "path": ["api", "enrollments"]
            }
          }
        },
        {
          "name": "GET /api/enrollments/my-courses - My enrolled courses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/enrollments/my-courses",
              "host": ["{{base_url}}"],
              "path": ["api", "enrollments", "my-courses"]
            }
          }
        },
        {
          "name": "POST /api/enrollments/{id}/progress - Mark lesson complete",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content_id\": 1,\n  \"is_completed\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/enrollments/1/progress",
              "host": ["{{base_url}}"],
              "path": ["api", "enrollments", "1", "progress"]
            }
          }
        }
      ]
    }
  ]
}
